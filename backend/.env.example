# =============================================================================
# LIFEBOOKZ - Backend Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# ---- Server ----
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1

# ---- MongoDB ----
# Get from: https://cloud.mongodb.com (Atlas free tier M0)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/lifebookz?retryWrites=true&w=majority

# ---- Redis (Upstash) ----
# Get from: https://console.upstash.com (Free tier: 100MB)
# Used for: session store, rate limiting, caching
REDIS_URL=redis://<username>:<password>@<region>-<id>.upstash.io:6379

# ---- Session & JWT ----
# Generate a strong random secret: openssl rand -hex 64
SESSION_SECRET=your-session-secret-at-least-32-chars-long
JWT_SECRET=your-jwt-secret-at-least-32-chars-long
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=30d

# ---- Google OAuth 2.0 ----
# Get from: https://console.cloud.google.com/apis/credentials
# Add redirect URI: http://localhost:3001/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# ---- AWS S3 (Media Storage) ----
# Get from: https://console.aws.amazon.com/iam (create IAM user with S3 full access)
# Bucket must allow public read, private write
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
S3_BUCKET=lifebookz-media
S3_MEDIA_BUCKET=lifebookz-media

# ---- AWS SQS (Queues) ----
# Get from: https://console.aws.amazon.com/sqs
# Create standard queues: embedding-queue, moderation-queue, notification-queue
SQS_EMBEDDING_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/embedding-queue
SQS_MODERATION_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/moderation-queue
SQS_NOTIFICATION_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/notification-queue

# ---- Qdrant Cloud (Vector Database) ----
# Get from: https://cloud.qdrant.io (Free tier: 1GB)
QDRANT_URL=https://<cluster-id>.us-east-1-0.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key

# ---- OpenRouter (AI / DeepSeek V4) ----
# Get from: https://openrouter.ai/keys (Free credits on signup)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-chat-v4

# ---- Frontend URL (CORS) ----
FRONTEND_URL=http://localhost:5173

# ---- Cookie Settings ----
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
